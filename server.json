{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.prompeteer/prompeteer-mcp",
  "description": "Generate expert AI prompts for 140+ platforms with 16-dimension quality scoring.",
  "repository": {
    "url": "https://github.com/prompeteer/prompeteer-mcp",
    "source": "github"
  },
  "version": "2.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@prompeteer.ai/mcp-server",
      "version": "2.0.0",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "remoteEndpoints": [
    {
      "transportType": "sse",
      "url": "https://prompeteer.ai/mcp/sse"
    },
    {
      "transportType": "streamable-http",
      "url": "https://prompeteer.ai/mcp"
    }
  ]
}
